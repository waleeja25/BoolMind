{
  "name": "node-typescript-boilerplate",
  "version": "0.0.0",
  "description": "Minimalistic boilerplate to quick-start Node.js development in TypeScript.",
  "author": "Jakub Synowiec <jsynowiec@users.noreply.github.com>",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">= 24.11 < 25"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@typescript-eslint/parser": "~8.59.0",
    "@vitest/coverage-v8": "~4.1.4",
    "@vitest/eslint-plugin": "~1.6.15",
    "eslint": "~10.2",
    "eslint-config-prettier": "~10.1",
    "globals": "~17.5.0",
    "prettier": "~3.8",
    "rimraf": "~6.1.3",
    "ts-api-utils": "~2.5.0",
    "tsx": "^4.23.1",
    "typeorm-ts-node-esm": "^0.3.20",
    "typescript": "~6.0.2",
    "typescript-eslint": "~8.59.0",
    "vitest": "~4.1.4"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node build/src/main.js",
    "clean": "rimraf coverage build tmp",
    "prebuild": "npm run lint && npm run check-types",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "npm run clean && tsc -p tsconfig.release.json",
    "lint": "eslint .",
    "test": "vitest run unit --config __tests__/vitest.config.ts",
    "test:coverage": "vitest run unit --config __tests__/vitest.config.ts --coverage.enabled --coverage.all",
    "test:watch": "vitest unit --config __tests__/vitest.config.ts",
    "prettier": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --write",
    "prettier:check": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --check",
    "migration:generate": "typeorm-ts-node-esm migration:generate src/database/migrations/InitialMigration -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-esm migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-esm migration:revert -d src/database/data-source.ts"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mysql2": "^3.23.0",
    "reflect-metadata": "^0.2.2",
    "tslib": "~2.8",
    "typeorm": "^1.1.0"
  }
}
